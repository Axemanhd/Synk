{
  "name": "synk-bot",
  "version": "1.0.8",
  "description": "Synk — A self-hosted Discord music bot with YouTube and Spotify playlist support",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
