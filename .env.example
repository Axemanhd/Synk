# Synk — Discord Music Bot
# Only 2 required values to get started.

# Discord Bot Token (required)
# Get from https://discord.com/developers/applications → Bot → Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Client ID (required for slash commands)
# Get from https://discord.com/developers/applications → OAuth2 → General
DISCORD_CLIENT_ID=your_discord_client_id_here

# Log Level (optional, default: info)
# Available: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
